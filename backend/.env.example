# OpenAI
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_VERIFICATION_MODEL=gpt-4o-mini
OPENAI_FINAL_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Playwright
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT=10000
OLTA_MAX_PAGES_PER_COLLECTION=16
OLTA_MAX_DETAIL_FETCH=96
ANSWER_CONTEXT_TOP_K=48
VERIFICATION_TARGET_CONFIDENCE=0.8
MAX_VERIFICATION_ROUNDS=5

# GPKI
GPKI_CERT_BASE_PATH=C:/Users/username/AppData/LocalLow/GPKI

# Server
HOST=127.0.0.1
PORT=8000
SESSION_TIMEOUT_MINUTES=30

# Mode (true = 가상 데이터 사용, false = 실제 연동)
USE_MOCK_CRAWLER=false
USE_MOCK_LLM=false
